{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/cadence-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Fraunces|Hanken Grotesk|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Fraunces, Hanken Grotesk, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|icon|title|children|onDismiss|style|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: variant, icon, title, children, onDismiss, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:insight|info|caution|alert|positive)$/]",
        "message": "<Banner> variant must be one of 'insight' | 'info' | 'caution' | 'alert' | 'positive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|icon|iconRight|children|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, icon, iconRight, children, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|md|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:night|interactive|padding|children|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: night, interactive, padding, children, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|helper|error|disabled|type|value|defaultValue|onChange|placeholder|id|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, helper, error, disabled, type, value, defaultValue, onChange, placeholder, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LiveIndicator'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|size|showLabel|style|key|ref|className|style|children)$/]",
        "message": "<LiveIndicator> doesn't accept that prop. Declared props: label, size, showLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|trend|trendTone|size|style|key|ref|className|style|children)$/]",
        "message": "<MetricStat> doesn't accept that prop. Declared props: label, value, unit, trend, trendTone, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute[name.name='trendTone'] > Literal[value!=/^(?:positive|caution|alert|info|neutral)$/]",
        "message": "<MetricStat> trendTone must be one of 'positive' | 'caution' | 'alert' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xl|md)$/]",
        "message": "<MetricStat> size must be one of 'xl' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|children|style|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: tone, dot, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:positive|caution|alert|info|neutral)$/]",
        "message": "<StatusPill> tone must be one of 'positive' | 'caution' | 'alert' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TopBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:night|logo|links|activeLink|onNavClick|cta|avatar|style|key|ref|className|style|children)$/]",
        "message": "<TopBar> doesn't accept that prop. Declared props: night, logo, links, activeLink, onNavClick, cta, avatar, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute > JSXIdentifier[name!=/^(?:width|height|animate|strokeWidth|color|style|key|ref|className|style|children)$/]",
        "message": "<Waveform> doesn't accept that prop. Declared props: width, height, animate, strokeWidth, color, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
